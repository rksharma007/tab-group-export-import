{
  "manifest_version": 3,
  "name": "Group Tabs \u2013 Export & Restore",
  "version": "1.0.0",
  "description": "Export your tab groups to a file and restore them in any Chrome or Edge browser. Fast, private, and fully offline.",
  "minimum_chrome_version": "89",
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Group Tabs \u2013 Export & Restore",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },
  "permissions": ["tabs", "tabGroups"]
}
